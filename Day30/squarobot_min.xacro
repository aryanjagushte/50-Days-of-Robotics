<?xml version="1.0" ?>
<robot name="squarobot_min" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find squarobot_min_description)/urdf/materials.xacro" />
<xacro:include filename="$(find squarobot_min_description)/urdf/squarobot_min.trans" />
<xacro:include filename="$(find squarobot_min_description)/urdf/squarobot_min.gazebo" />
<link name="base_link">
  <inertial>
    <origin xyz="-0.00011625600504186132 1.0955809809750335e-17 0.028625804629664083" rpy="0 0 0"/>
    <mass value="3.2583321237301512"/>
    <inertia ixx="0.002825" iyy="0.005895" izz="0.00811" ixy="-0.0" iyz="0.0" ixz="-1e-06"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find squarobot_min_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find squarobot_min_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="lidar_1">
  <inertial>
    <origin xyz="-3.618764437576268e-18 -7.237528875152536e-18 0.0050000000000000044" rpy="0 0 0"/>
    <mass value="0.1541343895667492"/>
    <inertia ixx="2.5e-05" iyy="2.5e-05" izz="4.8e-05" ixy="-0.0" iyz="-0.0" ixz="-0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.0 -0.0 -0.059" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find squarobot_min_description)/meshes/lidar_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.0 -0.0 -0.059" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find squarobot_min_description)/meshes/lidar_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="camera_1">
  <inertial>
    <origin xyz="-0.015 0.0 0.0050000000000000044" rpy="0 0 0"/>
    <mass value="0.00785"/>
    <inertia ixx="0.0" iyy="0.0" izz="0.0" ixy="0.0" iyz="0.0" ixz="-0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.075 -0.0 -0.039" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find squarobot_min_description)/meshes/camera_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.075 -0.0 -0.039" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find squarobot_min_description)/meshes/camera_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="caster_1">
  <inertial>
    <origin xyz="0.05 0.0 -0.005593749999999998" rpy="0 0 0"/>
    <mass value="0.026305602486058535"/>
    <inertia ixx="1e-06" iyy="1e-06" izz="1e-06" ixy="0.0" iyz="-0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.0 -0.0 -0.014" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find squarobot_min_description)/meshes/caster_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.0 -0.0 -0.014" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find squarobot_min_description)/meshes/caster_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="right_wheel_1">
  <inertial>
    <origin xyz="1.3877787807814457e-17 -0.004999999999999984 0.0" rpy="0 0 0"/>
    <mass value="0.15413438956674924"/>
    <inertia ixx="2.5e-05" iyy="4.8e-05" izz="2.5e-05" ixy="0.0" iyz="-0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.06 0.058 -0.025" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find squarobot_min_description)/meshes/right_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.06 0.058 -0.025" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find squarobot_min_description)/meshes/right_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="left_wheel_1">
  <inertial>
    <origin xyz="1.3877787807814457e-17 0.0049999999999999975 0.0" rpy="0 0 0"/>
    <mass value="0.15413438956674924"/>
    <inertia ixx="2.5e-05" iyy="4.8e-05" izz="2.5e-05" ixy="-0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.06 -0.058 -0.025" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find squarobot_min_description)/meshes/left_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.06 -0.058 -0.025" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find squarobot_min_description)/meshes/left_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<joint name="lidar_joint" type="fixed">
  <origin xyz="0.0 0.0 0.059" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="lidar_1"/>
</joint>

<joint name="camera_joint" type="fixed">
  <origin xyz="0.075 0.0 0.039" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="camera_1"/>
</joint>

<joint name="caster_joint" type="fixed">
  <origin xyz="0.0 0.0 0.014" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="caster_1"/>
</joint>

<joint name="right_wheel_joint" type="continuous">
  <origin xyz="-0.06 -0.058 0.025" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="right_wheel_1"/>
  <axis xyz="0.0 1.0 0.0"/>
</joint>

<joint name="left_wheel_joint" type="continuous">
  <origin xyz="-0.06 0.058 0.025" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="left_wheel_1"/>
  <axis xyz="0.0 1.0 0.0"/>
</joint>

</robot>
